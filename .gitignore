# ============ Old Times Papers — .gitignore ============
# On versionne le CODE et la DOC, pas les modèles/données/artefacts lourds.

# --- Python ---
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# --- Poids / modèles (lourds, re-téléchargeables) ---
*.pt
*.pth
*.mlmodel
*.onnx
*.h5
*.ckpt
digital-twin/benchmark/comp/models/
digital-twin/models/
*.gguf
block-detection/training/runs/
block-detection/training/dataset/
block-detection/training/dataset_blocs/

# --- Données / scans / caches ---
block-detection/annotation/data/
app/cache/
*.jpg
*.jpeg
*.zip
*.tar
*.tar.gz

# --- Crops & intermédiaires OCR (régénérables) ---
digital-twin/benchmark/crops/
digital-twin/benchmark/crops_test/
digital-twin/benchmark/_pre/
digital-twin/benchmark/_tune/
digital-twin/benchmark/comp/_tess/
digital-twin/out/

# --- Sorties OCR / rapports générés ---
digital-twin/benchmark/results*.json
digital-twin/benchmark/*_all.json
digital-twin/benchmark/comp/res_*.json
digital-twin/benchmark/*.html
digital-twin/benchmark/comp/*.html

# --- Archive de scripts exploratoires (superseded, gardés en local) ---
digital-twin/benchmark/attic/

# --- Divers ---
*.log
.DS_Store
Thumbs.db
